{
  "name": "songlab",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:sync": "concurrently -n vite,server -c blue,green \"vite --host\" \"tsx watch server/index.ts\"",
    "build": "tsc -b && vite build",
    "start": "node --import tsx server/index.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@coderline/alphatab": "^1.8.1",
    "@wavesurfer/react": "^1.0.12",
    "express": "^5.1.0",
    "idb": "^8.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "wavesurfer.js": "^7.12.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@coderline/alphatab-vite": "^1.8.1",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "^5.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
